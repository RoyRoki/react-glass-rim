{
  "name": "react-glass-rim",
  "version": "0.1.0",
  "description": "React glassmorphism rim / edge-light effect — add an Apple-style liquid-glass border highlight to any element. Tiny hook + drop-in component, zero runtime dependencies, SSR/Next.js safe.",
  "keywords": [
    "react",
    "glass",
    "glassmorphism",
    "liquid-glass",
    "apple-glass",
    "frosted-glass",
    "glass-effect",
    "glass-border",
    "glass-card",
    "rim",
    "rim-light",
    "edge-light",
    "border-highlight",
    "specular",
    "backdrop-blur",
    "frosted",
    "border",
    "gradient",
    "conic-gradient",
    "ui",
    "ui-components",
    "react-component",
    "react-hook",
    "hook",
    "nextjs",
    "tailwind"
  ],
  "license": "MIT",
  "author": "Roki Roy (https://rokiroy.in)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/royroki/react-glass-rim.git"
  },
  "homepage": "https://rokiroy.in",
  "bugs": {
    "url": "https://github.com/royroki/react-glass-rim/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "playground": "pnpm --filter react-glass-rim-playground dev",
    "prepublishOnly": "pnpm test && pnpm build"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  }
}
